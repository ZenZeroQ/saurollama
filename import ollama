import ollama
import os

# 1. Definimos la "Herramienta" que el agente puede usar
def obtener_uso_cpu():
    print(">>> [Agente ejecutando comando real: top]...")
    stream = os.popen("top -bn1 | grep 'Cpu(s)'")
    return stream.read()

# 2. Configuramos el pensamiento del modelo
prompt_sistema = (
    "Eres un asistente de diagnóstico. Si el usuario te pregunta por el estado del sistema, "
    "debes responder UNICAMENTE con la palabra: CONSULTAR_CPU. "
    "Si es un saludo o algo general, responde normal."
)

usuario_input = input("¿En qué puedo ayudarte hoy? ")

# 3. La IA decide qué hacer
response = ollama.chat(model='gemma:2b', messages=[
    {'role': 'system', 'content': prompt_sistema},
    {'role': 'user', 'content': usuario_input},
])

decision = response['message']['content'].strip()

# 4. El script actúa basado en la decisión de la IA
if "CONSULTAR_CPU" in decision:
    datos_reales = obtener_uso_cpu()
    # Le pasamos los datos reales de vuelta a la IA para que los explique
    analisis = ollama.chat(model='gemma:2b', messages=[
        {'role': 'user', 'content': f"Los datos reales del sistema son: {datos_reales}. Explícalos de forma breve al usuario."}
    ])
    print("\n--- Respuesta del Agente ---")
    print(analisis['message']['content'])
else:
    print("\n--- Respuesta de la IA ---")
    print(decision)